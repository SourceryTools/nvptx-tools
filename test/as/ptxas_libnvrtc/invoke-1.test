RUN: sed -e 's|sm_%target_as_arch0|sm_GHI|g' < dummy_ptxas_log.golden > %t.dummy_ptxas_log.golden
RUN: cmp %t.dummy_ptxas_log.golden %t.dummy_ptxas_log
RUN: ! test -s %t.stdout
RUN: sed -e 's|sm_%target_as_arch0|sm_GHI|g' < verbose_stderr.golden > %t.stderr.golden
RUN: cmp %t.stderr.golden %t.stderr


