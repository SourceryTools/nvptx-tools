What happens if use of 'ptxas' is inhibited.


'--no-verify'

RUN: rm -f %t*
RUN: %target_as_local_cmd --inhibit=ptxas --no-verify %S/../bare-1.s -o %t.o > %t.stdout 2> %t.stderr
RUN: cmp %S/../bare-1.s %t.o
RUN: ! test -s %t.stdout
RUN: ! test -s %t.stderr

'-v'

RUN: rm -f %t*
RUN: %target_as_local_cmd --inhibit=ptxas --no-verify -v %S/../bare-1.s -o %t.o > %t.stdout 2> %t.stderr
RUN: cmp %S/../bare-1.s %t.o
RUN: ! test -s %t.stdout
RUN: ! test -s %t.stderr


'--verify'

RUN: rm -f %t*
RUN: %target_as_local_cmd --inhibit=ptxas --verify %S/../bare-1.s -o %t.o > %t.stdout 2> %t.stderr; r=$?; [ x"$r" = x1 ]
RUN: ! test -s %t.o
RUN: ! test -s %t.stdout
RUN: echo "nvptx-as: not able to verify output" >> %t.stderr.golden
RUN: cmp %t.stderr.golden %t.stderr

'-v'

RUN: rm -f %t*
RUN: %target_as_local_cmd --inhibit=ptxas --verify -v %S/../bare-1.s -o %t.o > %t.stdout 2> %t.stderr; r=$?; [ x"$r" = x1 ]
RUN: ! test -s %t.o
RUN: ! test -s %t.stdout
RUN: echo "use of 'ptxas' inhibited" >> %t.stderr.golden
RUN: echo "nvptx-as: not able to verify output" >> %t.stderr.golden
RUN: cmp %t.stderr.golden %t.stderr


Implicit '--verify'

RUN: rm -f %t*
RUN: %target_as_local_cmd --inhibit=ptxas %S/../bare-1.s -o %t.o > %t.stdout 2> %t.stderr
RUN: cmp %S/../bare-1.s %t.o
RUN: ! test -s %t.stdout
RUN: ! test -s %t.stderr

'-v'

RUN: rm -f %t*
RUN: %target_as_local_cmd --inhibit=ptxas -v %S/../bare-1.s -o %t.o > %t.stdout 2> %t.stderr
RUN: cmp %S/../bare-1.s %t.o
RUN: ! test -s %t.stdout
RUN: echo "use of 'ptxas' inhibited" >> %t.stderr.golden
RUN: echo "not able to verify output" >> %t.stderr.golden
RUN: cmp %t.stderr.golden %t.stderr
