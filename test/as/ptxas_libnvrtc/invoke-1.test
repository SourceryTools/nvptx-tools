Test when 'ptxas' doesn't get invoked, and when it does, and how.

REQUIRES: as_libnvrtc_usable


RUN: sed -e 's|sm_50|sm_%target_as_arch0|g' < %S/../ptxas/dummy_ptxas_log.golden > dummy_ptxas_log.golden
RUN: sed -e 's|sm_50|sm_%target_as_arch0|g' < %S/../ptxas/verbose_stderr.golden > verbose_stderr.golden
RUN: sed -e 's|sm_50|sm_%target_as_arch0|g' < %S/../ptxas/verbose_stderr-sm_30.golden > verbose_stderr-sm_30.golden

RUN: sed -e '1{/^use of NVRTC library inhibited$/d}' -i verbose_stderr.golden
RUN: sed -e '1{/^use of NVRTC library inhibited$/d}' -i verbose_stderr-sm_30.golden


'--help'

RUN: rm -f %t*
RUN: %target_as_dummy_ptxas_cmd --help
RUN: ! test -f %t.dummy_ptxas_log


'--version'

RUN: rm -f %t*
RUN: %target_as_dummy_ptxas_cmd --version
RUN: ! test -f %t.dummy_ptxas_log


No output file

RUN: rm -f %t*
RUN: %target_as_dummy_ptxas_cmd -v %S/../bare-1.s > %t.stdout 2> %t.stderr
RUN: ! test -f %t.dummy_ptxas_log
RUN: cmp %S/../bare-1.s %t.stdout
RUN: ! test -s %t.stderr


'--no-verify'

RUN: rm -f %t*
RUN: %target_as_dummy_ptxas_cmd -v --no-verify -o /dev/null %S/../bare-1.s > %t.stdout 2> %t.stderr
RUN: ! test -f %t.dummy_ptxas_log
RUN: ! test -s %t.stdout
RUN: ! test -s %t.stderr


'--verify'

RUN: rm -f %t*
RUN: %target_as_dummy_ptxas_cmd -v --verify -o /dev/null %S/../bare-1.s > %t.stdout 2> %t.stderr
RUN: cmp dummy_ptxas_log.golden %t.dummy_ptxas_log
RUN: ! test -s %t.stdout
RUN: cmp verbose_stderr-sm_30.golden %t.stderr


Implicit '--verify'

RUN: rm -f %t*
RUN: %target_as_dummy_ptxas_cmd -v -o /dev/null %S/../bare-1.s > %t.stdout 2> %t.stderr
RUN: cmp dummy_ptxas_log.golden %t.dummy_ptxas_log
RUN: ! test -s %t.stdout
RUN: cmp verbose_stderr-sm_30.golden %t.stderr


Implicit '--verify', '-m sm_2020'

RUN: rm -f %t*
RUN: %target_as_dummy_ptxas_cmd -v -o /dev/null %S/../bare-1.s -m sm_2020 > %t.stdout 2> %t.stderr
RUN: sed -e 's|sm_%target_as_arch0|sm_2020|g' < dummy_ptxas_log.golden > %t.dummy_ptxas_log.golden
RUN: cmp %t.dummy_ptxas_log.golden %t.dummy_ptxas_log
RUN: ! test -s %t.stdout
RUN: sed -e 's|sm_%target_as_arch0|sm_2020|g' < verbose_stderr.golden > %t.stderr.golden
RUN: cmp %t.stderr.golden %t.stderr


Implicit '--verify', preamble '.target sm_2022'

RUN: rm -f %t*
RUN: sed -e 's|sm_30|sm_2022|g' < %S/../bare-1.s > %t.bare-1.s
RUN: %target_as_dummy_ptxas_cmd -v -o /dev/null %t.bare-1.s > %t.stdout 2> %t.stderr
RUN: sed -e 's|sm_%target_as_arch0|sm_2022|g' < dummy_ptxas_log.golden > %t.dummy_ptxas_log.golden
RUN: cmp %t.dummy_ptxas_log.golden %t.dummy_ptxas_log
RUN: ! test -s %t.stdout
RUN: sed -e 's|sm_%target_as_arch0|sm_2022|g' < verbose_stderr.golden > %t.stderr.golden
RUN: cmp %t.stderr.golden %t.stderr


Implicit '--verify', '-m ABC'

RUN: rm -f %t*
RUN: %target_as_dummy_ptxas_cmd -v -o /dev/null %S/../bare-1.s -m ABC > %t.stdout 2> %t.stderr
RUN: sed -e 's|sm_%target_as_arch0|ABC|g' < dummy_ptxas_log.golden > %t.dummy_ptxas_log.golden
RUN: cmp %t.dummy_ptxas_log.golden %t.dummy_ptxas_log
RUN: ! test -s %t.stdout
RUN: sed -e 's|sm_%target_as_arch0|ABC|g' < verbose_stderr.golden > %t.stderr.golden
RUN: cmp %t.stderr.golden %t.stderr


Implicit '--verify', preamble '.target DEF'

RUN: rm -f %t*
RUN: sed -e 's|sm_30|DEF|g' < %S/../bare-1.s > %t.bare-1.s
RUN: %target_as_dummy_ptxas_cmd -v -o /dev/null %t.bare-1.s > %t.stdout 2> %t.stderr; r=$?; [ x"$r" = x1 ]
RUN: ! test -f %t.dummy_ptxas_log
RUN: ! test -s %t.stdout
RUN: echo 'nvptx-as: unsupported '\''.target DEF'\'' directive in preamble' >> %t.stderr.golden
RUN: cmp %t.stderr.golden %t.stderr


