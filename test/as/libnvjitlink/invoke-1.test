Test when the nvJitLink library doesn't get invoked, and when it does, and how.

We can't (easily) test everything that's tested in '../ptxas/invoke-1.test'.
Instead of '%target_as_dummy_ptxas_cmd', we have to rely on scanning '-v' output, and we may only do that if:
REQUIRES: as_libnvjitlink_usable


The template '[...].golden' files that we generate as part of some test run
include all output that we control, but not what the nvJitLink library provides
(which is unpredictable).  We then 'cmp' the "golden" vs. actual files until
before the trailing newline.


'--help'


'--version'


No output file

RUN: rm -f %t*
RUN: %target_as_local_cmd -v %S/../bare-1.s > %t.stdout 2> %t.stderr
RUN: cmp %S/../bare-1.s %t.stdout
RUN: ! test -s %t.stderr


'--no-verify'

RUN: rm -f %t*
RUN: %target_as_local_cmd -v --no-verify -o /dev/null %S/../bare-1.s > %t.stdout 2> %t.stderr
RUN: ! test -s %t.stdout
RUN: ! test -s %t.stderr


'--verify'

As part of this also generate the template 'verbose_stderr-sm_30.golden'.

RUN: rm -f verbose_stderr-sm_30.golden

RUN: rm -f %t*
RUN: %target_as_local_cmd -v --verify -o /dev/null %S/../bare-1.s > %t.stdout 2> %t.stderr; r=$?; [ x"$r" = x1 ]
RUN: ! test -s %t.stdout
RUN: sed -n -e '1{/^Verifying sm_30 code with sm_%target_as_arch0 code generation\.$/p}' < %t.stderr >> verbose_stderr-sm_30.golden
RUN: sed -n -e '2{/^nvJitLink library verification: '\''\/dev\/null'\'', '\''-arch=sm_%target_as_arch0'\''.*/p}' < %t.stderr >> verbose_stderr-sm_30.golden
RUN: sed -n -e '3s|^\(nvptx-as: nvJitLinkAddFile failed: \).*|\1|p' < %t.stderr >> verbose_stderr-sm_30.golden
RUN: f=verbose_stderr-sm_30.golden && s=$( wc -c < "$f" ) && n=$(( s - 1 )) && cmp -n "$n" "$f" %t.stderr


Implicit '--verify'

RUN: rm -f %t*
RUN: %target_as_local_cmd -v -o /dev/null %S/../bare-1.s > %t.stdout 2> %t.stderr; r=$?; [ x"$r" = x1 ]
RUN: ! test -s %t.stdout
RUN: f=verbose_stderr-sm_30.golden && s=$( wc -c < "$f" ) && n=$(( s - 1 )) && cmp -n "$n" "$f" %t.stderr


Implicit '--verify', '-m sm_2020'

As part of this also generate the template 'verbose_stderr.golden'.
RUN: rm -f verbose_stderr.golden

RUN: rm -f %t*
RUN: %target_as_local_cmd -v -o /dev/null %S/../bare-1.s -m sm_2020 > %t.stdout 2> %t.stderr; r=$?; [ x"$r" = x1 ]
RUN: ! test -s %t.stdout
RUN: sed -n -e '1{/^nvJitLink library verification: '\''\/dev\/null'\'', '\''-arch=sm_2020'\''.*/p}' < %t.stderr >> verbose_stderr.golden
RUN: sed -n -e '2s|^\(nvptx-as: nvJitLinkCreate failed: \).*|\1|p' < %t.stderr >> verbose_stderr.golden
RUN: f=verbose_stderr.golden && s=$( wc -c < "$f" ) && n=$(( s - 1 )) && cmp -n "$n" "$f" %t.stderr

RUN: sed -e 's|sm_2020|sm_%target_as_arch0|' -i verbose_stderr.golden


Implicit '--verify', preamble '.target sm_2022'

RUN: rm -f %t*
RUN: sed -e 's|sm_30|sm_2022|g' < %S/../bare-1.s > %t.bare-1.s
RUN: %target_as_local_cmd -v -o /dev/null %t.bare-1.s > %t.stdout 2> %t.stderr; r=$?; [ x"$r" = x1 ]
RUN: ! test -s %t.stdout
RUN: sed -e 's|sm_%target_as_arch0|sm_2022|g' < verbose_stderr.golden > %t.stderr.golden
RUN: f=%t.stderr.golden && s=$( wc -c < "$f" ) && n=$(( s - 1 )) && cmp -n "$n" "$f" %t.stderr


