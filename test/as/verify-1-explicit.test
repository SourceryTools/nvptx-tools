Aspects of explicit '--verify'.

REQUIRES: as_ptxas_usable


'bare-1.s'

'ptxas' with NVRTC library (if usable):

RUN: rm -f %t*
RUN: %target_as_cmd --verify %S/bare-1.s -o %t.o > %t.stdout 2> %t.stderr
RUN: cmp %S/bare-1.s %t.o
RUN: ! test -s %t.stdout
RUN: ! test -s %t.stderr

'ptxas' without NVRTC library:

RUN: rm -f %t*
RUN: %target_as_cmd --verify --inhibit=libnvrtc %target_as_m_sm_arch0 %S/bare-1.s -o %t.o > %t.stdout 2> %t.stderr
RUN: cmp %S/bare-1.s %t.o
RUN: ! test -s %t.stdout
RUN: ! test -s %t.stderr


'garbage-1.s'

(Full verification not actually invoked here.)

RUN: rm -f %t*
RUN: %target_as_cmd --verify %S/garbage-1.s -o %t.o > %t.stdout 2> %t.stderr; r=$?; [ x"$r" = x1 ]
RUN: ! test -f %t.o
RUN: ! test -s %t.stdout
RUN: < %t.stderr grep -qe '%r_target_as_missing_version_directive'


'whitespace-1.s'

(Full verification not actually invoked here.)

RUN: rm -f %t*
RUN: %target_as_cmd --verify %S/whitespace-1.s -o %t.o > %t.stdout 2> %t.stderr; r=$?; [ x"$r" = x1 ]
RUN: ! test -f %t.o
RUN: ! test -s %t.stdout
RUN: < %t.stderr grep -qe '%r_target_as_missing_version_directive'
