What happens if the nvJitLink library isn't usable.

We can't (easily) do like '../ptxas/unusable-ptxas-1-PATH.test', so we really only run this if:
UNSUPPORTED: as_libnvjitlink_usable


'--no-verify'

RUN: rm -f %t*
RUN: %target_as_local_cmd --no-verify %S/../bare-1.s -o %t.o > %t.stdout 2> %t.stderr
RUN: cmp %S/../bare-1.s %t.o
RUN: ! test -s %t.stdout
RUN: ! test -s %t.stderr

'-v'

RUN: rm -f %t*
RUN: %target_as_local_cmd --no-verify -v %S/../bare-1.s -o %t.o > %t.stdout 2> %t.stderr
RUN: cmp %S/../bare-1.s %t.o
RUN: ! test -s %t.stdout
RUN: ! test -s %t.stderr


'--verify'

RUN: rm -f %t*
RUN: %target_as_local_cmd --verify %S/../bare-1.s -o %t.o > %t.stdout 2> %t.stderr; r=$?; [ x"$r" = x1 ]
RUN: ! test -s %t.o
RUN: ! test -s %t.stdout
RUN: echo "nvptx-as: not able to verify output" >> %t.stderr.golden
RUN: cmp %t.stderr.golden %t.stderr

'-v'

RUN: rm -f %t*
RUN: %target_as_local_cmd --verify -v %S/../bare-1.s -o %t.o > %t.stdout 2> %t.stderr; r=$?; [ x"$r" = x1 ]
RUN: ! test -s %t.o
RUN: ! test -s %t.stdout
RUN: sed -n -e '1{/^nvJitLink library not usable: .*/p}' < %t.stderr >> %t.stderr.golden
RUN: echo "use of 'ptxas' inhibited" >> %t.stderr.golden
RUN: echo "nvptx-as: not able to verify output" >> %t.stderr.golden
RUN: cmp %t.stderr.golden %t.stderr


Implicit '--verify'

RUN: rm -f %t*
RUN: %target_as_local_cmd %S/../bare-1.s -o %t.o > %t.stdout 2> %t.stderr
RUN: cmp %S/../bare-1.s %t.o
RUN: ! test -s %t.stdout
RUN: ! test -s %t.stderr

'-v'

RUN: rm -f %t*
RUN: %target_as_local_cmd -v %S/../bare-1.s -o %t.o > %t.stdout 2> %t.stderr
RUN: cmp %S/../bare-1.s %t.o
RUN: ! test -s %t.stdout
RUN: sed -n -e '1{/^nvJitLink library not usable: .*/p}' < %t.stderr >> %t.stderr.golden
RUN: echo "use of 'ptxas' inhibited" >> %t.stderr.golden
RUN: echo "not able to verify output" >> %t.stderr.golden
RUN: cmp %t.stderr.golden %t.stderr
