RUN: sed -e 's|sm_30|sm_-1|g' < %S/../bare-1.s > %t.bare-1.s
RUN: %target_as_dummy_ptxas_cmd -v -o /dev/null %t.bare-1.s > %t.stdout 2> %t.stderr; r=$?; [ x"$r" = x1 ]
