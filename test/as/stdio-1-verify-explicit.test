Functionality implemented in commit 08b0896a71925d4e033be40abdd23cf08a41a5da "restore ability to use stdin/stdout".

See 'stdio-1.test'; these here are explicit '--verify' variants.

REQUIRES: as_libnvjitlink_usable || as_ptxas_usable


'bare-1.s'

'stdin'

nvJitLink library (if usable):

RUN: rm -f %t*
RUN: %target_as_cmd --verify < %S/bare-1.s -o %t.o > %t.stdout 2> %t.stderr
RUN: cmp %S/bare-1.s %t.o
RUN: ! test -s %t.stdout
RUN: ! test -s %t.stderr

'ptxas' with NVRTC library (if usable):

RUN: rm -f %t*
RUN: %target_as_cmd --verify --inhibit=libnvjitlink < %S/bare-1.s -o %t.o > %t.stdout 2> %t.stderr
RUN: cmp %S/bare-1.s %t.o
RUN: ! test -s %t.stdout
RUN: ! test -s %t.stderr

'ptxas' without NVRTC library:

RUN: rm -f %t*
RUN: %target_as_cmd --verify --inhibit=libnvjitlink --inhibit=libnvrtc %target_as_m_sm_arch0 < %S/bare-1.s -o %t.o > %t.stdout 2> %t.stderr
RUN: cmp %S/bare-1.s %t.o
RUN: ! test -s %t.stdout
RUN: ! test -s %t.stderr
