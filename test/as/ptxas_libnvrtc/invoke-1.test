Preamble '.target sm_35': special-cased to '--gpu-name sm_%target_as_arch0' (if applicable).

RUN: rm -f %t*
RUN: sed -e 's|sm_30|sm_35|g' < %S/../bare-1.s > %t.bare-1.s
RUN: %target_as_dummy_ptxas_cmd -v -o /dev/null %t.bare-1.s > %t.stdout 2> %t.stderr
RUN: cp dummy_ptxas_log.golden %t.dummy_ptxas_log.golden
RUN: if expr 35 \< '%target_as_arch0' > /dev/null; then :; else sed -e 's|sm_%target_as_arch0|sm_35|g' -i %t.dummy_ptxas_log.golden; fi
RUN: cmp %t.dummy_ptxas_log.golden %t.dummy_ptxas_log
RUN: ! test -s %t.stdout
RUN: if expr 35 \< '%target_as_arch0' > /dev/null; then sed -e 's|sm_30|sm_35|g' < verbose_stderr-sm_30.golden; else sed -e 's|sm_%target_as_arch0|sm_35|g' < verbose_stderr.golden; fi > %t.stderr.golden
RUN: cmp %t.stderr.golden %t.stderr

